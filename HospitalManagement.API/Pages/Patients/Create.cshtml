@page
@model HospitalManagement.API.Pages.Patients.CreateModel
@{
    ViewData["Title"] = "New Patient";
}

<div class="page-header">
    <h2><i class="bi bi-person-plus text-primary"></i> New Patient</h2>
    <p class="text-muted">Register a new patient in the system</p>
</div>

<div class="card stat-card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <h5 class="mb-3 text-primary"><i class="bi bi-person"></i> Personal Information</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Patient.FileNumber" class="form-label fw-bold">File Number *</label>
                    <input asp-for="Patient.FileNumber" class="form-control" placeholder="PAT-001" />
                    <span asp-validation-for="Patient.FileNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Patient.FirstName" class="form-label fw-bold">First Name *</label>
                    <input asp-for="Patient.FirstName" class="form-control" placeholder="Jean" />
                    <span asp-validation-for="Patient.FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Patient.LastName" class="form-label fw-bold">Last Name *</label>
                    <input asp-for="Patient.LastName" class="form-control" placeholder="Dupont" />
                    <span asp-validation-for="Patient.LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Patient.DateOfBirth" class="form-label fw-bold">Date of Birth *</label>
                    <input asp-for="Patient.DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="Patient.DateOfBirth" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Patient.Email" class="form-label fw-bold">Email *</label>
                    <input asp-for="Patient.Email" type="email" class="form-control" placeholder="jean@email.com" />
                    <span asp-validation-for="Patient.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Patient.Phone" class="form-label fw-bold">Phone</label>
                    <input asp-for="Patient.Phone" class="form-control" placeholder="+33612345678" />
                </div>
            </div>

            <h5 class="mb-3 text-primary"><i class="bi bi-geo-alt"></i> Address</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Patient.Street" class="form-label">Street</label>
                    <input asp-for="Patient.Street" class="form-control" placeholder="10 Rue de la Paix" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Patient.City" class="form-label">City</label>
                    <input asp-for="Patient.City" class="form-control" placeholder="Paris" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Patient.ZipCode" class="form-label">Zip Code</label>
                    <input asp-for="Patient.ZipCode" class="form-control" placeholder="75001" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Patient.Country" class="form-label">Country</label>
                    <input asp-for="Patient.Country" class="form-control" placeholder="France" />
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-between">
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Create Patient
                </button>
            </div>
        </form>
    </div>
</div>