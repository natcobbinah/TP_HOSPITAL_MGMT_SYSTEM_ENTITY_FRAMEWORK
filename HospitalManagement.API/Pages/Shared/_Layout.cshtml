<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Hospital Management</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
          rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" 
          rel="stylesheet" />
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="d-flex">
        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <nav class="sidebar d-flex flex-column">
            <div class="sidebar-brand">
                <i class="bi bi-hospital"></i> HospitalMgr
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" 
                       asp-page="/Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <small class="text-muted px-3 text-uppercase" style="font-size:0.7rem; letter-spacing:0.1em;">
                        Management
                    </small>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Patients") == true ? "active" : "")" 
                       asp-page="/Patients/Index">
                        <i class="bi bi-people"></i> Patients
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Doctors") == true ? "active" : "")" 
                       asp-page="/Doctors/Index">
                        <i class="bi bi-person-badge"></i> Doctors
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Departments") == true ? "active" : "")" 
                       asp-page="/Departments/Index">
                        <i class="bi bi-building"></i> Departments
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Consultations") == true ? "active" : "")" 
                       asp-page="/Consultations/Index">
                        <i class="bi bi-calendar-check"></i> Consultations
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <small class="text-muted px-3 text-uppercase" style="font-size:0.7rem; letter-spacing:0.1em;">
                        Dashboards
                    </small>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Dashboard/PatientRecord" ? "active" : "")" 
                       asp-page="/Dashboard/PatientRecord">
                        <i class="bi bi-file-medical"></i> Patient Record
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Dashboard/DoctorPlanning" ? "active" : "")" 
                       asp-page="/Dashboard/DoctorPlanning">
                        <i class="bi bi-calendar3"></i> Doctor Planning
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Dashboard/DepartmentStats" ? "active" : "")" 
                       asp-page="/Dashboard/DepartmentStats">
                        <i class="bi bi-bar-chart-line"></i> Dept. Statistics
                    </a>
                </li>
            </ul>

            <div class="mt-auto p-3">
                <a href="/swagger" target="_blank" class="nav-link text-muted" style="font-size:0.8rem;">
                    <i class="bi bi-code-slash"></i> API Swagger
                </a>
            </div>
        </nav>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <main class="main-content flex-grow-1">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
