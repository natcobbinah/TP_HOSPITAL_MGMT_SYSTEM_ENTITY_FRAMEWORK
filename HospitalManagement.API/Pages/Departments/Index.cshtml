@page
@model HospitalManagement.API.Pages.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-building"></i> Departments</h2>
        <p class="text-muted mb-0">Manage hospital departments</p>
    </div>
    <a asp-page="Create" class="btn btn-warning">
        <i class="bi bi-plus-circle"></i> New Department
    </a>
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Location</th>
                    <th>Head Doctor</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Departments)
                {
                    <tr>
                        <td><strong>@d.Name</strong></td>
                        <td><i class="bi bi-geo-alt text-muted"></i> @(string.IsNullOrEmpty(d.Location) ? "N/A" : d.Location)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(d.HeadDoctorName))
                            {
                                <span class="badge bg-success"><i class="bi bi-person-badge"></i> @d.HeadDoctorName</span>
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-page="/Dashboard/DepartmentStats" class="btn btn-sm btn-outline-warning" title="Stats">
                                <i class="bi bi-bar-chart"></i>
                            </a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@d.Id"
                                  class="d-inline" onsubmit="return confirm('Delete this department?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Departments.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state py-4">
                                <i class="bi bi-building-x d-block" style="font-size:2rem;opacity:0.3;"></i>
                                <p class="mb-0">No departments yet. Create one to get started.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>