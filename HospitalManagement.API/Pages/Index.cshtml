@page
@model HospitalManagement.API.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2><i class="bi bi-speedometer2"></i> Hospital Dashboard</h2>
    <p class="text-muted">Overview of the hospital management system</p>
</div>

<!-- ═══════ STAT CARDS ═══════ -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <div class="stat-value text-primary">@Model.TotalPatients</div>
                    <div class="stat-label">Patients</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-success bg-opacity-10 text-success me-3">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div>
                    <div class="stat-value text-success">@Model.TotalDoctors</div>
                    <div class="stat-label">Doctors</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3">
                    <i class="bi bi-building-fill"></i>
                </div>
                <div>
                    <div class="stat-value text-warning">@Model.TotalDepartments</div>
                    <div class="stat-label">Departments</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════ QUICK LINKS ═══════ -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <a asp-page="/Dashboard/PatientRecord" class="text-decoration-none">
            <div class="card stat-card border-start border-primary border-4">
                <div class="card-body">
                    <h5><i class="bi bi-file-medical text-primary"></i> Patient Record</h5>
                    <p class="text-muted mb-0">View patient files with consultation history</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Dashboard/DoctorPlanning" class="text-decoration-none">
            <div class="card stat-card border-start border-success border-4">
                <div class="card-body">
                    <h5><i class="bi bi-calendar3 text-success"></i> Doctor Planning</h5>
                    <p class="text-muted mb-0">View upcoming schedules for doctors</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-page="/Dashboard/DepartmentStats" class="text-decoration-none">
            <div class="card stat-card border-start border-warning border-4">
                <div class="card-body">
                    <h5><i class="bi bi-bar-chart-line text-warning"></i> Department Stats</h5>
                    <p class="text-muted mb-0">Doctor and consultation counts per department</p>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- ═══════ DEPARTMENT OVERVIEW TABLE ═══════ -->
<div class="card stat-card">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-building"></i> Department Overview</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Location</th>
                    <th class="text-center">Doctors</th>
                    <th class="text-center">Consultations</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.DepartmentStats)
                {
                    <tr>
                        <td><strong>@dept.Name</strong></td>
                        <td>@dept.Location</td>
                        <td class="text-center">
                            <span class="badge bg-success rounded-pill">@dept.DoctorCount</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">@dept.ConsultationCount</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
