@page
@model HospitalManagement.API.Pages.Dashboard.PatientRecordModel
@{
    ViewData["Title"] = "Patient Record";
}

<div class="page-header">
    <h2><i class="bi bi-file-medical text-primary"></i> Patient Record</h2>
    <p class="text-muted">View a patient's complete file with all consultation history</p>
</div>

<!-- ═══════ PATIENT SELECTOR ═══════ -->
<div class="card stat-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label fw-bold">Select a Patient</label>
                <select asp-for="PatientId" asp-items="Model.PatientList" class="form-select form-select-lg">
                    <option value="">-- Choose a patient --</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-search"></i> View Record
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.PatientDetail != null)
{
    var patient = Model.PatientDetail;

    <!-- ═══════ PATIENT INFO CARD ═══════ -->
    <div class="card stat-card mb-4">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-person-circle"></i> @patient.FullName
                </h4>
                <span class="badge bg-light text-primary fs-6">@patient.FileNumber</span>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <p class="mb-1 text-muted small">DATE OF BIRTH</p>
                    <p class="fw-bold"><i class="bi bi-calendar3"></i> @patient.DateOfBirth.ToString("dd MMMM yyyy")</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-1 text-muted small">EMAIL</p>
                    <p class="fw-bold"><i class="bi bi-envelope"></i> @patient.Email</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-1 text-muted small">PHONE</p>
                    <p class="fw-bold"><i class="bi bi-telephone"></i> @(string.IsNullOrEmpty(patient.Phone) ? "N/A" : patient.Phone)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════ CONSULTATION HISTORY ═══════ -->
    <div class="card stat-card">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-clock-history"></i> Consultation History
                <span class="badge bg-secondary rounded-pill ms-2">@patient.Consultations.Count</span>
            </h5>
        </div>
        <div class="card-body">
            @if (patient.Consultations.Any())
            {
                <div class="timeline">
                    @foreach (var consultation in patient.Consultations)
                    {
                        var statusClass = consultation.Status.ToLower();
                        var badgeClass = consultation.Status switch
                        {
                            "Planned" => "badge-planned",
                            "Completed" => "badge-completed",
                            "Cancelled" => "badge-cancelled",
                            _ => "bg-secondary"
                        };

                        <div class="timeline-item @statusClass mb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="bi bi-person-badge"></i> @consultation.DoctorName
                                    </h6>
                                    <p class="text-muted mb-1">
                                        <i class="bi bi-calendar-event"></i>
                                        @consultation.Date.ToString("dddd, dd MMM yyyy — HH:mm")
                                    </p>
                                    @if (!string.IsNullOrEmpty(consultation.Reason))
                                    {
                                        <p class="mb-1"><strong>Reason:</strong> @consultation.Reason</p>
                                    }
                                    @if (!string.IsNullOrEmpty(consultation.Notes))
                                    {
                                        <p class="mb-0 fst-italic text-muted">
                                            <i class="bi bi-journal-text"></i> @consultation.Notes
                                        </p>
                                    }
                                </div>
                                <span class="badge @badgeClass">@consultation.Status</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-calendar-x d-block"></i>
                    <h5>No Consultations</h5>
                    <p>This patient has no consultation records yet.</p>
                </div>
            }
        </div>
    </div>
}
else if (Model.PatientId.HasValue)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Patient not found.
    </div>
}
