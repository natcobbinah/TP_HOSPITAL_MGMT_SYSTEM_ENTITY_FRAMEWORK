@page
@model HospitalManagement.API.Pages.Dashboard.DepartmentStatsModel
@{
    ViewData["Title"] = "Department Statistics";
}

<div class="page-header">
    <h2><i class="bi bi-bar-chart-line text-warning"></i> Department Statistics</h2>
    <p class="text-muted">Overview of doctors and consultations per department</p>
</div>

<!-- ═══════ SUMMARY CARDS ═══════ -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <div class="stat-value text-warning">@Model.Stats.Count()</div>
                    <div class="stat-label">Departments</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-success bg-opacity-10 text-success me-3">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <div class="stat-value text-success">@Model.TotalDoctors</div>
                    <div class="stat-label">Total Doctors</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <div>
                    <div class="stat-value text-primary">@Model.TotalConsultations</div>
                    <div class="stat-label">Total Consultations</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════ DEPARTMENT TABLE ═══════ -->
<div class="card stat-card mb-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="bi bi-table"></i> Department Breakdown</h5>
    </div>
    <div class="card-body p-0">
        @if (Model.Stats.Any())
        {
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th style="width: 5%">#</th>
                        <th style="width: 30%">Department</th>
                        <th style="width: 25%">Location</th>
                        <th class="text-center" style="width: 15%">Doctors</th>
                        <th class="text-center" style="width: 15%">Consultations</th>
                        <th class="text-center" style="width: 10%">Ratio</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var index = 0; }
                    @foreach (var dept in Model.Stats)
                    {
                        index++;
                        var ratio = dept.DoctorCount > 0
                            ? (dept.ConsultationCount / (double)dept.DoctorCount).ToString("F1")
                            : "—";

                        <tr>
                            <td class="text-muted">@index</td>
                            <td>
                                <strong>@dept.Name</strong>
                            </td>
                            <td>
                                <i class="bi bi-geo-alt text-muted"></i>
                                @(string.IsNullOrEmpty(dept.Location) ? "N/A" : dept.Location)
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success bg-opacity-10 text-success fs-6 px-3 py-2">
                                    <i class="bi bi-person-badge"></i> @dept.DoctorCount
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-primary bg-opacity-10 text-primary fs-6 px-3 py-2">
                                    <i class="bi bi-calendar-check"></i> @dept.ConsultationCount
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="text-muted" title="Consultations per doctor">
                                    @ratio c/d
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-building-x d-block"></i>
                <h5>No Departments</h5>
                <p>Create departments to see statistics here.</p>
                <a asp-page="/Departments/Create" class="btn btn-warning">
                    <i class="bi bi-plus-circle"></i> Add Department
                </a>
            </div>
        }
    </div>
</div>

<!-- ═══════ VISUAL BARS ═══════ -->
@if (Model.Stats.Any())
{
    var maxConsultations = Model.Stats.Max(s => s.ConsultationCount);
    maxConsultations = maxConsultations == 0 ? 1 : maxConsultations; // prevent division by zero

    <div class="card stat-card">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Visual Comparison</h5>
        </div>
        <div class="card-body">
            @foreach (var dept in Model.Stats.OrderByDescending(s => s.ConsultationCount))
            {
                var doctorPct = Model.TotalDoctors > 0
                    ? (int)(dept.DoctorCount / (double)Model.TotalDoctors * 100) : 0;
                var consultPct = (int)(dept.ConsultationCount / (double)maxConsultations * 100);

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <strong>@dept.Name</strong>
                        <span class="text-muted">@dept.DoctorCount doctors · @dept.ConsultationCount consultations</span>
                    </div>
                    <div class="progress mb-1" style="height: 12px;">
                        <div class="progress-bar bg-success" role="progressbar"
                             style="width: @(doctorPct)%"
                             title="@dept.DoctorCount doctors">
                        </div>
                    </div>
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar bg-primary" role="progressbar"
                             style="width: @(consultPct)%"
                             title="@dept.ConsultationCount consultations">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mt-1">
                        <small class="text-success">■ Doctors</small>
                        <small class="text-primary">■ Consultations</small>
                    </div>
                </div>
            }
        </div>
    </div>
}
