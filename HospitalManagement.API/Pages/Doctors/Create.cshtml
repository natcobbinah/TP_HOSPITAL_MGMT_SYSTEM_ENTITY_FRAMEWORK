@page
@model HospitalManagement.API.Pages.Doctors.CreateModel
@{
    ViewData["Title"] = "New Doctor";
}

<div class="page-header">
    <h2><i class="bi bi-person-badge text-success"></i> New Doctor</h2>
    <p class="text-muted">Register a new doctor in the hospital</p>
</div>

<div class="card stat-card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger"
                 style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="Doctor.FirstName" class="form-label fw-bold">First Name *</label>
                    <input asp-for="Doctor.FirstName" class="form-control" placeholder="Marie" />
                    <span asp-validation-for="Doctor.FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Doctor.LastName" class="form-label fw-bold">Last Name *</label>
                    <input asp-for="Doctor.LastName" class="form-control" placeholder="Bernard" />
                    <span asp-validation-for="Doctor.LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Doctor.LicenseNumber" class="form-label fw-bold">License Number *</label>
                    <input asp-for="Doctor.LicenseNumber" class="form-control" placeholder="LIC-001" />
                    <span asp-validation-for="Doctor.LicenseNumber" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Doctor.Specialty" class="form-label fw-bold">Specialty *</label>
                    <select asp-for="Doctor.Specialty" asp-items="Model.SpecialtyList" class="form-select">
                        <option value="">-- Select specialty --</option>
                    </select>
                    <span asp-validation-for="Doctor.Specialty" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Doctor.DepartmentId" class="form-label fw-bold">Department *</label>
                    <select asp-for="Doctor.DepartmentId" asp-items="Model.DepartmentList" class="form-select">
                        <option value="">-- Select department --</option>
                    </select>
                    <span asp-validation-for="Doctor.DepartmentId" class="text-danger small"></span>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-between">
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Register Doctor
                </button>
            </div>
        </form>
    </div>
</div>